{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "samriddhi-estates/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "samriddhi-estates/backend/**",
      "maxDuration": 10
    }
  }
}
